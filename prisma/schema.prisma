generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id               String   @id @default(cuid())
  fullName         String
  professionalRole String
  constituency     String
  skills           String[]
  idea             String
  createdAt        DateTime @default(now())
}
